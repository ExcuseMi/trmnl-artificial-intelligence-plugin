{% assign view = 1 %}

{% if _leaderboard == null %}
  {% render "no_data", trmnl: trmnl, icon: icon %}
{% else %}
{% assign top = _leaderboard.models[0] %}

<div class="layout  layout--col gap--space-between w--full">
  <div class="flex flex--row mb--5 w--full bg--gray-75">
    <div class="item stretch grow bg--black text--white  rounded p--2">
      <div class="content">
        <div class="value" data-clamp="1">{{top.name | escape }}</div>
    </div>

    </div>
    <div class="item item--emphasis-2">
      <div class="meta"></div>
      <div class="content">
        {% if top.elo %}
          <span class="value value--tnums">{{ top.elo }}</span>
          <span class="label">#1 ELO</span>
        {% else %}
          <span class="value value--tnums">{{ top.intelligence }}</span>
          <span class="label">#1 Intelligence</span>
        {% endif %}
      </div>
    </div>
    {% unless top.elo %}
    <div class="item item--emphasis-2 md:portrait:hidden">
      <div class="meta"></div>
      <div class="content">
        <span class="value value--tnums">{{ top.speed_tps }}</span>
        <span class="label">token/s</span>
      </div>
    </div>
    <div class="item item--emphasis-2 md:hidden lg:flex">
      <div class="meta"></div>
      <div class="content">
        <span class="value value--tnums">${{ top.price_output }}</span>
        <span class="label">$/M out</span>
      </div>
    </div>
    {% else %}
    <div class="item item--emphasis-2 md:portrait:hidden">
      <div class="meta"></div>
      <div class="content">
        <span class="value value--tnums">{{ _leaderboard.total_models }}</span>
        <span class="label">models</span>
      </div>
    </div>
    {% endunless %}
  </div>

  <script src="https://trmnl.com/js/highcharts/12.3.0/highcharts.js"></script>
  <script src="https://trmnl.com/js/highcharts/12.3.0/pattern-fill.js"></script>

  {% assign chart_id_md = 'ai-chart-md' | append_random %}
  {% assign chart_id_lg = 'ai-chart-lg' | append_random %}
  <div id="{{ chart_id_md }}" class="w--full grow h--min-0 lg:hidden"></div>
  <div id="{{ chart_id_lg }}" class="w--full grow h--min-0 md:hidden lg:block"></div>

  <script>
    var allCategories = [{% for model in _leaderboard.models %}"{{ model.name }}"{% unless forloop.last %},{% endunless %}{% endfor %}];
    var allIntelligence = [{% for model in _leaderboard.models %}{{ model.intelligence }}{% unless forloop.last %},{% endunless %}{% endfor %}];
    {% unless top.elo %}
    var allCoding = [{% for model in _leaderboard.models %}{{ model.coding | default: 'null' }}{% unless forloop.last %},{% endunless %}{% endfor %}];
    {% endunless %}

    function makeChart(id, limit, labelClass, showCreator) {
      var categories = allCategories.slice(0, limit);
      var creatorCategories = [{% for model in _leaderboard.models %}"{{ model.name }}|{{ model.creator }}"{% unless forloop.last %},{% endunless %}{% endfor %}].slice(0, limit);

      {% if top.elo %}
        var series = [{
          name: "ELO",
          data: [{% for model in _leaderboard.models %}{{ model.elo }}{% unless forloop.last %},{% endunless %}{% endfor %}].slice(0, limit),
          colorByPoint: true,
        }];
      {% else %}
        var series = [
          { name: "Intelligence", data: allIntelligence.slice(0, limit).map(function(v, i) { return i === 0 ? { y: v, color: "#000000" } : v; }), color: "#444444" },
          { name: "Coding", data: allCoding.slice(0, limit), color: { pattern: { image: "https://trmnl.com/images/grayscale/gray-5.png", width: 12, height: 12 } } },
        ];
      {% endif %}

      Highcharts.chart(id, {
        {% if top.elo %}
        colors: ["#111111", "#2d2d2d", "#494949", "#666666", "#828282", "#9e9e9e", "#b4b4b4", "#c8c8c8", "#d8d8d8", "#e8e8e8"],
        {% endif %}
        chart: { type: "bar", animation: false, spacing: [0, 0, 0, 0], style: { fontFamily: "var(--label-font-family)", WebkitFontSmoothing: "var(--label-font-smoothing)", fontSize: "var(--label-font-size)", fontWeight: "var(--label-font-weight)" } },
        title: { text: null },
        xAxis: {
          categories: showCreator ? creatorCategories : categories,
          reversed: true,
          labels: {
            step: 1,
            style: { color: "#000" },
            formatter: function() {
              var weight = this.pos === 0 ? "bold" : "normal";
              if (showCreator) {
                var parts = this.value.split("|");
                var name = parts[0].length > 36 ? parts[0].substring(0, 35) + "…" : parts[0];
                return '<span class="' + labelClass + '" style="font-weight:' + weight + ';">' + name + '</span>'
                     + '<br/><span class="label" style="font-weight:' + weight + ';">' + (parts[1] || "") + '</span>';
              }
              var name = this.value.length > 26 ? this.value.substring(0, 25) + "…" : this.value;
              return '<span class="' + labelClass + '" style="font-weight:' + weight + ';">' + name + '</span>';
            },
          },
          lineWidth: 0, tickWidth: 0, gridLineWidth: 0,
        },
        yAxis: {
          title: { text: null },
          labels: { style: { color: "#000" } },
          gridLineDashStyle: "shortdot", gridLineColor: "#000", tickAmount: 4,
        },
        legend: { enabled: series.length > 1, align: "left", verticalAlign: "bottom", itemStyle: { color: "#000" }, symbolRadius: 0 },
        plotOptions: {
          series: {
            animation: false, enableMouseTracking: false,
            states: { hover: { enabled: false } },
            pointPadding: 0.02, groupPadding: 0.05,
          },
        },
        series: series,
        tooltip: { enabled: false },
        credits: { enabled: false },
      });
    }

    document.addEventListener("DOMContentLoaded", function() {
      makeChart("{{ chart_id_md }}", 5,  "label",       false);
      makeChart("{{ chart_id_lg }}", 10, "value--small", false);
    });
  </script>
</div>

{% render "title_bar", trmnl: trmnl, data: data, icon: icon, _view_label:_view_label %}
{% endif %}
